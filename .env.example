# ==========================================
#  AGY-QQ-Bridge 环境变量配置模板 (.env.example)
# ==========================================

# 1. QQ 官方机器人接口凭证（请在 QQ 开放平台应用管理后台获取）
APP_ID=your_app_id_here
CLIENT_SECRET=your_client_secret_here

# 2. 管理员用户 OpenID（在此填入您自己的 C2C OpenID，桥接器只响应您发送的私聊消息）
MASTER_OPENID=your_master_openid_here

# 3. 本地保活的 tmux 虚拟终端 Session 名称（默认使用 "0"）
TMUX_SESSION=0

# 4. AGY 脑部结构化日志 transcript.jsonl 存放的主目录
# 默认值：指向当前用户家目录下的路径。对于 root 用户通常为 /root/.gemini/antigravity-cli/brain
# BRAIN_DIR=/root/.gemini/antigravity-cli/brain

# 5.  logs/ 
# LOG_DIR=./logs

# 6.  QQ  /new  /reset  tmux  AGY 
#  AGY  tmux 
#  agy  PATH   script -q -c 
AGY_START_CMD=cd ~ && agy --dangerously-skip-permissions
#  AGY_START_CMD=script -q -c "/root/.local/bin/agy --dangerously-skip-permissions" /dev/null
